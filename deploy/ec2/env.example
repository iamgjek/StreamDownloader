APP_DIR=/opt/stream-downloader
APP_USER=ubuntu
APP_GROUP=ubuntu
HOST=0.0.0.0
PORT=8000

# 請務必改成隨機長字串（例如 openssl rand -hex 32）
SECRET_KEY=replace_with_secure_secret

# 多個網域請用逗號分隔，且不要加尾斜線
# 例如：https://your-app.vercel.app,https://www.your-domain.com
CORS_ORIGINS=https://your-app.vercel.app

# 預設先用 SQLite；若改 PostgreSQL 可填 postgresql://...
DATABASE_URL=sqlite:////opt/stream-downloader/backend/data/users.db

# 選用：字幕搜尋
OPENSUBTITLES_API_KEY=

# 選用：YouTube cookies（避免 bot 驗證）
YTDLP_COOKIES=
